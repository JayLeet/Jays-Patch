# Handle live-game Storyteller tool clicks.
tag @a remove botc_st_tool_used
function botc_patch:storyteller_tools/dashboard/tick
execute if score phase game_data matches 3 as @a[tag=storyteller,tag=botc_st_nom_action,tag=botc_st_nom_vote_started,tag=!botc_st_nom_vote_finished] if entity @a[tag=botc_st_nom_selected,tag=last_nom,limit=1] run function botc_patch:storyteller_tools/nomination_menu/vote_finished
execute if score phase game_data matches 1..2 as @a[tag=storyteller,scores={botc_hand_use=1..},tag=!botc_st_tool_used] if data entity @s SelectedItem.components."minecraft:custom_model_data"{strings:["storyteller_passage"]} run function botc_patch:storyteller_tools/passage/start
execute if score phase game_data matches 4 as @a[tag=storyteller,tag=in_house,scores={botc_hand_use=1..},tag=!botc_st_tool_used] if data entity @s SelectedItem.components."minecraft:custom_model_data"{strings:["storyteller_passage"]} run function botc_patch:storyteller_tools/passage/start
execute unless score patch_dialog_mode botc_patch matches 1 if score phase game_data matches 1..3 as @a[tag=storyteller,scores={botc_hand_use=1..},tag=!botc_st_tool_used] if data entity @s SelectedItem.components."minecraft:custom_data"{botc_storyteller_timer:1b} run function botc_patch:storyteller_tools/timer/open
execute unless score patch_dialog_mode botc_patch matches 1 if score phase game_data matches 1..2 as @a[tag=storyteller,scores={botc_hand_use=1..},tag=!botc_st_tool_used] if data entity @s SelectedItem.components."minecraft:custom_model_data"{strings:["storyteller_post_kill"]} run function botc_patch:storyteller_tools/kill_menu/open
execute unless score patch_dialog_mode botc_patch matches 1 if score phase game_data matches 1..2 as @a[tag=storyteller,scores={botc_hand_use=1..},tag=!botc_st_tool_used] if data entity @s SelectedItem.components."minecraft:custom_model_data"{strings:["storyteller_revive"]} run function botc_patch:storyteller_tools/revive_menu/open
execute unless score patch_dialog_mode botc_patch matches 1 if score phase game_data matches 3 as @a[tag=storyteller,scores={botc_hand_use=1..},tag=!botc_st_tool_used] if data entity @s SelectedItem.components."minecraft:custom_model_data"{strings:["storyteller_post_kill"]} run function botc_patch:storyteller_tools/post_execution/kill
execute unless score patch_dialog_mode botc_patch matches 1 if score phase game_data matches 3 as @a[tag=storyteller,tag=botc_st_post_execution,scores={botc_hand_use=1..},tag=!botc_st_tool_used] if data entity @s SelectedItem.components."minecraft:custom_model_data"{strings:["botc_role_boomdandy"]} run function botc_patch:storyteller_tools/post_execution/boomdandy
execute unless score patch_dialog_mode botc_patch matches 1 if score phase game_data matches 3 as @a[tag=storyteller,scores={botc_hand_use=1..},tag=!botc_st_tool_used] if data entity @s SelectedItem.components."minecraft:custom_model_data"{strings:["storyteller_nominate"]} run function botc_patch:storyteller_tools/nomination_menu/open
execute if score phase game_data matches 3 as @a[tag=storyteller,scores={botc_hand_use=1..},tag=!botc_st_tool_used] if data entity @s SelectedItem.components."minecraft:custom_model_data"{strings:["storyteller_nom_back"]} run function botc_patch:storyteller_tools/nomination_menu/back
execute if score phase game_data matches 3 as @a[tag=storyteller,scores={botc_hand_use=1..},tag=!botc_st_tool_used] if data entity @s SelectedItem.components."minecraft:custom_model_data"{strings:["storyteller_nom_start_vote"]} run function botc_patch:storyteller_tools/nomination_menu/start_vote
execute if score phase game_data matches 3 as @a[tag=storyteller,scores={botc_hand_use=1..},tag=!botc_st_tool_used] if data entity @s SelectedItem.components."minecraft:custom_model_data"{strings:["storyteller_nom_mark"]} run function botc_patch:storyteller_tools/nomination_menu/mark
execute unless score patch_dialog_mode botc_patch matches 1 if score phase game_data matches 3 as @a[tag=storyteller,scores={botc_hand_use=1..},tag=!botc_st_tool_used] if data entity @s SelectedItem.components."minecraft:custom_model_data"{strings:["storyteller_nom_pyre"]} run function botc_patch:storyteller_tools/nomination_menu/pyre
execute unless score patch_dialog_mode botc_patch matches 1 if score phase game_data matches 3 as @a[tag=storyteller,scores={botc_hand_use=1..},tag=!botc_st_tool_used] if data entity @s SelectedItem.components."minecraft:custom_model_data"{strings:["storyteller_nom_execute"]} run function botc_patch:storyteller_tools/nomination_menu/execute
execute unless score patch_dialog_mode botc_patch matches 1 if score phase game_data matches 4 as @a[tag=storyteller,scores={botc_hand_use=1..},tag=!botc_st_tool_used] if data entity @s SelectedItem.components."minecraft:custom_model_data"{strings:["storyteller_tp_player_menu"]} run function botc_patch:storyteller_tools/player_menu/open
execute unless score patch_dialog_mode botc_patch matches 1 if score phase game_data matches 4 as @a[tag=storyteller,scores={botc_hand_use=1..},tag=!botc_st_tool_used] if data entity @s SelectedItem.components."minecraft:custom_model_data"{strings:["storyteller_reset_game"]} run function botc_patch:storyteller_tools/reset_game
execute if score patch_dialog_mode botc_patch matches 1 if score grim_active botc_patch matches 1 if score phase game_data matches 4 as @a[tag=storyteller,scores={botc_hand_use=1..},tag=!botc_st_tool_used] if data entity @s SelectedItem.components."minecraft:custom_model_data"{strings:["storyteller_reset_game"]} run function botc_patch:storyteller_tools/reset_game
execute unless score patch_dialog_mode botc_patch matches 1 if score phase game_data matches 1.. as @a[tag=storyteller,scores={botc_hand_use=1..},tag=!botc_st_tool_used] if data entity @s SelectedItem.components."minecraft:custom_model_data"{strings:["storyteller_advance_phase"]} run function botc_patch:storyteller_tools/advance_phase
execute unless score patch_dialog_mode botc_patch matches 1 if score phase game_data matches 4 as @a[tag=storyteller,scores={botc_hand_use=1..},tag=!botc_st_tool_used] if data entity @s SelectedItem.components."minecraft:custom_model_data"{strings:["storyteller_tp_evil"]} run function botc_patch:storyteller_tools/teleport_evil
execute unless score patch_dialog_mode botc_patch matches 1 if score phase game_data matches 1..3 as @a[tag=storyteller,scores={botc_hand_use=1..},tag=!botc_st_tool_used] if data entity @s SelectedItem.components."minecraft:custom_model_data"{strings:["storyteller_tp_seats"]} run function botc_patch:storyteller_tools/teleport_seats
execute unless score patch_dialog_mode botc_patch matches 1 if score phase game_data matches 4 as @a[tag=storyteller,scores={botc_hand_use=1..},tag=!botc_st_tool_used] if data entity @s SelectedItem.components."minecraft:custom_model_data"{strings:["storyteller_tp_home"]} run function botc_patch:storyteller_tools/teleport_home
scoreboard players set @a[tag=botc_st_tool_used] botc_hand_use 0
scoreboard players set @a[tag=botc_st_tool_used] botc_music_use 0
tag @a remove botc_st_tool_used
