# Open custom-script import without changing the currently selected setup.
tag @s add botc_setup_room_used
playsound minecraft:block.note_block.bass voice @s ~ ~ ~ 0.6 0.8
dialog show @s {type:"multi_action",title:{text:"",font:"botc_patch:role_icons",color:"white",extra:[{text:" Custom Script",font:"minecraft:default",color:"white"}]},inputs:[{type:"text",key:"script",label:"Script JSON",max_length:20000}],actions:[{label:{text:"",font:"botc_patch:role_icons",color:"white",extra:[{text:" Import Script",font:"minecraft:default",color:"gold",bold:true}]},action:{type:"minecraft:dynamic/run_command",template:"/setupbag import \"$(script)\""}},{label:{text:"",font:"botc_patch:ui_icons",color:"white",extra:[{text:" Cancel",font:"minecraft:default",color:"gray"}]},action:{type:"run_command",command:"/setupbag cancel_import"}}]}
