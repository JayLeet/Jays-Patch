# Select the parent Grimoire Tools icon for role notifications not yet opened in that submenu.
data modify storage botc_patch:grim notifications.grimoire_tools_font set value "botc_patch:ui_icons"
execute if score phase game_data matches 4 unless score grim_active botc_patch matches 1 if score grim_notice_fearmonger_menu_seen botc_patch matches 0 if score grim_notice_fearmonger_done botc_patch matches 0 if entity @a[tag=!storyteller,tag=!spectator,scores={id=1..15,role=108}] run data modify storage botc_patch:grim notifications.grimoire_tools_font set value "botc_patch:ui_icons_notification"
execute if score phase game_data matches 4 unless score grim_active botc_patch matches 1 if score grim_notice_banshee_menu_seen botc_patch matches 0 if score grim_notice_banshee_done botc_patch matches 0 if entity @a[tag=!storyteller,tag=!spectator,tag=dead,tag=!active_banshee,scores={id=1..15,role=55}] run data modify storage botc_patch:grim notifications.grimoire_tools_font set value "botc_patch:ui_icons_notification"
execute if score phase game_data matches 4 unless score grim_active botc_patch matches 1 if score grim_notice_alhadikhia_menu_seen botc_patch matches 0 if score grim_notice_alhadikhia_done botc_patch matches 0 if entity @a[tag=!storyteller,tag=!spectator,scores={id=1..15,role=128}] run data modify storage botc_patch:grim notifications.grimoire_tools_font set value "botc_patch:ui_icons_notification"
execute if score phase game_data matches 3 unless score grim_active botc_patch matches 1 if score grim_notice_madness_menu_seen botc_patch matches 0 if score grim_notice_madness_done botc_patch matches 0 if entity @a[tag=!storyteller,tag=!spectator,scores={id=1..15,role=100}] run data modify storage botc_patch:grim notifications.grimoire_tools_font set value "botc_patch:ui_icons_notification"
