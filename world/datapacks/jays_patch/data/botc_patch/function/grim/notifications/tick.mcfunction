# Raise the outer badge once for each available, unseen role action.
scoreboard players set grim_notice_pending botc_patch 0
execute if score phase game_data matches 4 unless score grim_active botc_patch matches 1 if score grim_notice_fearmonger_seen botc_patch matches 0 if score grim_notice_fearmonger_done botc_patch matches 0 if entity @a[tag=!storyteller,tag=!spectator,scores={id=1..15,role=108}] run scoreboard players set grim_notice_pending botc_patch 1
execute if score phase game_data matches 4 unless score grim_active botc_patch matches 1 if score grim_notice_banshee_seen botc_patch matches 0 if score grim_notice_banshee_done botc_patch matches 0 if entity @a[tag=!storyteller,tag=!spectator,tag=!active_banshee,scores={id=1..15,role=55}] run scoreboard players set grim_notice_pending botc_patch 1
execute if score phase game_data matches 4 unless score grim_active botc_patch matches 1 if score grim_notice_alhadikhia_seen botc_patch matches 0 if score grim_notice_alhadikhia_done botc_patch matches 0 if entity @a[tag=!storyteller,tag=!spectator,scores={id=1..15,role=128}] run scoreboard players set grim_notice_pending botc_patch 1
execute if score phase game_data matches 3 unless score grim_active botc_patch matches 1 if score grim_notice_madness_seen botc_patch matches 0 if score grim_notice_madness_done botc_patch matches 0 if entity @a[tag=!storyteller,tag=!spectator,scores={id=1..15,role=100}] run scoreboard players set grim_notice_pending botc_patch 1
execute if score phase game_data matches 3 if score grim_notice_boomdandy_seen botc_patch matches 0 if score grim_notice_boomdandy_done botc_patch matches 0 if entity @a[tag=storyteller,tag=botc_st_post_execution] if entity @a[tag=!storyteller,tag=!spectator,scores={id=1..15,role=107}] run scoreboard players set grim_notice_pending botc_patch 1

# Request an immediate repair only when the held model no longer matches the pending state.
execute if score grim_notice_pending botc_patch matches 1 as @a[tag=storyteller] if data entity @s Inventory[].components."minecraft:custom_model_data"{strings:["grim_reveal_menu"]} run scoreboard players set botc_item_maintenance_pending botc_patch 1
execute if score grim_notice_pending botc_patch matches 0 as @a[tag=storyteller] if data entity @s Inventory[].components."minecraft:custom_model_data"{strings:["grim_reveal_menu_notification"]} run scoreboard players set botc_item_maintenance_pending botc_patch 1
